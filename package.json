{
  "name": "@neutro/view",
  "version": "0.1.0",
  "description": "High-performance, framework-portable, fine-grained reactive view engine.",
  "type": "module",
  "license": "MIT",
  "author": "Kofi",
  "homepage": "https://github.com/neutro-web/view",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neutro-web/view.git"
  },
  "bugs": {
    "url": "https://github.com/neutro-web/view/issues"
  },
  "keywords": [
    "reactive",
    "signals",
    "fine-grained",
    "view",
    "ui",
    "no-vdom",
    "web-components",
    "compiler",
    "framework-agnostic"
  ],
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    },
    "./renderer/runtime": {
      "types": "./dist/renderer/runtime.d.ts",
      "import": "./dist/renderer/runtime.js"
    },
    "./renderer/plugin": {
      "types": "./dist/renderer/nv-esbuild-plugin.d.ts",
      "import": "./dist/renderer/nv-esbuild-plugin.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "jsdom": "^28.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm build",
    "test:browser": "playwright test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "alien-signals": "3.1.2",
    "esbuild": "^0.28.1",
    "lefthook": "^1.8.0",
    "serve": "^14.2.6",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "vitepress": "^1.3.0"
  }
}
