{
  "name": "@neutro/view",
  "version": "0.0.0",
  "description": "High-performance, framework-portable, fine-grained reactive view engine.",
  "type": "module",
  "license": "MIT",
  "author": "Kofi",
  "homepage": "https://github.com/neutro-web/view",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neutro-web/view.git"
  },
  "bugs": {
    "url": "https://github.com/neutro-web/view/issues"
  },
  "keywords": [
    "reactive",
    "signals",
    "fine-grained",
    "view",
    "ui",
    "no-vdom",
    "web-components",
    "compiler",
    "framework-agnostic"
  ],
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.0",
    "lefthook": "^1.8.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
