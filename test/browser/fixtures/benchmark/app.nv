const App = $component(() => {
  $script(() => {
    const rows = signal([])
    const selected = signal(0)
    let nextId = 1

    const A = ['pretty', 'large', 'big', 'small', 'tall', 'short', 'long', 'handsome', 'plain', 'quaint', 'clean', 'elegant', 'easy', 'angry', 'crazy', 'helpful', 'mushy', 'odd', 'unsightly', 'adorable', 'important', 'inexpensive', 'cheap', 'expensive', 'fancy']
    const C = ['red', 'yellow', 'blue', 'green', 'pink', 'brown', 'purple', 'brown', 'white', 'black', 'orange']
    const N = ['table', 'chair', 'house', 'bbq', 'desk', 'car', 'pony', 'cookie', 'sandwich', 'burger', 'pizza', 'mouse', 'keyboard']

    function rnd(max) { return Math.round(Math.random() * 1000) % max }
    function buildLabel() { return A[rnd(A.length)] + ' ' + C[rnd(C.length)] + ' ' + N[rnd(N.length)] }
    function buildRows(count) {
      const arr = []
      for (let i = 0; i < count; i++) arr.push({ id: nextId++, label: buildLabel() })
      return arr
    }
    function swapAt(arr, a, b) {
      if (arr.length <= b) return arr
      const copy = arr.slice()
      const tmp = copy[a]
      copy[a] = copy[b]
      copy[b] = tmp
      return copy
    }
  })
  $render(() => html`
    <div id="main">
      <div class="container">
        <div class="jumbotron">
          <div class="row">
            <div class="col-md-6"><h1>nv</h1></div>
            <div class="col-md-6">
              <div class="row">
                <div class="col-sm-6 smallpad">
                  <button id="run" class="btn btn-primary btn-block" type="button" @click="${() => rows = buildRows(1000)}">Create 1,000 rows</button>
                </div>
                <div class="col-sm-6 smallpad">
                  <button id="runlots" class="btn btn-primary btn-block" type="button" @click="${() => rows = buildRows(10000)}">Create 10,000 rows</button>
                </div>
                <div class="col-sm-6 smallpad">
                  <button id="add" class="btn btn-primary btn-block" type="button" @click="${() => rows = [...rows(), ...buildRows(1000)]}">Append 1,000 rows</button>
                </div>
                <div class="col-sm-6 smallpad">
                  <button id="update" class="btn btn-primary btn-block" type="button" @click="${() => rows = rows().map((r, i) => i % 10 === 0 ? { id: r.id, label: r.label + ' !!!' } : r)}">Update every 10th row</button>
                </div>
                <div class="col-sm-6 smallpad">
                  <button id="clear" class="btn btn-primary btn-block" type="button" @click="${() => rows = []}">Clear</button>
                </div>
                <div class="col-sm-6 smallpad">
                  <button id="swaprows" class="btn btn-primary btn-block" type="button" @click="${() => rows = swapAt(rows(), 1, 998)}">Swap Rows</button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <table class="table table-hover table-striped test-data">
          <tbody id="tbody">
            <each .of="${rows}" key="${(row) => row.id}" let={item}><tr class="${{ danger: selected() === item.id }}"><td class="col-md-1">${item.id}</td><td class="col-md-4"><a class="lbl" @click="${() => selected = item.id}">${item.label}</a></td><td class="col-md-1"><a class="remove" @click="${() => rows = rows().filter(r => r.id !== item.id)}"><span class="remove glyphicon glyphicon-remove" aria-hidden="true"></span></a></td><td class="col-md-6"></td></tr></each>
          </tbody>
        </table>
        <span class="preloadicon glyphicon glyphicon-remove" aria-hidden="true"></span>
      </div>
    </div>
  `)
})
