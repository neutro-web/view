// Task 3 (pt1b-i-swr) — .nv authoring-surface fixture proving the parser accepts
// <switch pending="..."> and forks to a DeferredSwapBinding. Not real-browser-gated
// here (that is Task 5's job); this fixture only exercises the parser.
const AppSwitchPending = $component(() => {
  $script(() => {
    const mode = signal(0)
    const loading = signal(false)
    function cycle() {
      mode.set((mode() + 1) % 3)
    }
  })
  $render(() => html`
    <div>
      <button id="cycle" @click="${() => cycle()}">Cycle</button>
      <switch pending="${loading}">
        <match when="${mode() === 0}"><div class="branch-0">Branch 0</div></match>
        <match when="${mode() === 1}"><div class="branch-1">Branch 1</div></match>
        <match><div class="branch-fb">Fallback</div></match>
      </switch>
    </div>
  `)
})
