const Empty = $component(() => {
  $render(() => html`<p class="empty-state">Nothing here</p>`)
})
const Panel = $component(() => {
  $script(() => {
    const hasItems = signal(false)
  })
  $render(() => html`<div><switch>
    <match when="${hasItems()}"><p>Has items</p></match>
    <match><Empty /></match>
  </switch></div>`)
})
